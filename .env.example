# ReactPress API (SSR — Next.js server requests)
REACTPRESS_API_URL=http://localhost:3002/api

# Browser CSR requests (same as SSR, or use same-origin /api via rewrites)
NEXT_PUBLIC_REACTPRESS_API_URL=http://localhost:3002/api

# Public site URL (SEO / sitemap / Open Graph)
CLIENT_SITE_URL=http://localhost:3001

# Subpath deployment (optional)
# BASE_PATH=/blog

# ── Mock mode (offline demo / CI / Vercel starter deploy) ───────────────────
# REACTPRESS_MOCK_API=1

# ── Remote API during dev (equivalent to --remote-origin) ───────────────────
# REACTPRESS_DEV_REMOTE_ORIGIN=https://api.yoursite.com

# ── Production (Vercel / self-hosted) ───────────────────────────────────────
# REACTPRESS_API_URL=https://api.yoursite.com/api
# NEXT_PUBLIC_REACTPRESS_API_URL=/api
# CLIENT_SITE_URL=https://www.yoursite.com
